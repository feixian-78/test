<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.KehuDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.cl.entity.KehuEntity" id="kehuMap">
        <result property="kehumingcheng" column="kehumingcheng"/>
        <result property="dizhi" column="dizhi"/>
        <result property="shoujihaoma" column="shoujihaoma"/>
    </resultMap>

    <select id="selectListView"
		resultType="com.cl.entity.view.KehuView" >

		SELECT  kehu.* FROM kehu  kehu 	        
         <choose>
        <when test="ew != null and ew.sqlSegment != null and ew.sqlSegment != '' and ew.sqlSegment.contains('WHERE')">
            <!-- 当SQL片段包含WHERE时，直接使用 -->
            ${ew.sqlSegment}
        </when>
        <when test="ew != null and ew.sqlSegment != null and ew.sqlSegment != '' and !ew.sqlSegment.toUpperCase().startsWith(' ORDER')">
            <!-- 当不包含WHERE且不以ORDER开头时，加WHERE -->
            WHERE ${ew.sqlSegment}
        </when>
        <when test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
            <!-- 其他情况（以ORDER开头）直接使用 -->
            ${ew.sqlSegment}
        </when>
    </choose>
	</select>
	
